{
  "name": "ecs-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "docs/*.md",
    "docs/zh/*.md",
    "dist/*.d.ts",
    "dist/*.js",
    "dist/*.js.map",
    "dist/internal/*.d.ts",
    "dist/internal/*.js",
    "dist/internal/*.js.map"
  ],
  "scripts": {
    "check": "npm run typecheck && npm run lint",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "pack:check": "npm pack --dry-run",
    "test": "node --import tsx --test tests/*.test.ts",
    "benchmark": "tsx benchmarks/ecs-benchmark.ts",
    "benchmark:json": "tsx benchmarks/ecs-benchmark.ts --json",
    "example:bundle": "tsx examples/bundle.ts",
    "example:changes": "tsx examples/change-detection.ts",
    "example:lifecycle": "tsx examples/lifecycle.ts",
    "example:messages": "tsx examples/messages.ts",
    "example:net-entity-map": "tsx examples/net-entity-map.ts",
    "example:per-system-changes": "tsx examples/per-system-change-detection.ts",
    "example:observer": "tsx examples/observer.ts",
    "example:query-advanced": "tsx examples/query-filter-advanced.ts",
    "example:query-ergonomics": "tsx examples/query-ergonomics.ts",
    "example:query": "tsx examples/query-filter.ts",
    "example:query-state": "tsx examples/query-state.ts",
    "example:removed": "tsx examples/removed-reader.ts",
    "example:required": "tsx examples/required-components.ts",
    "example:resources": "tsx examples/resource-change-detection.ts",
    "example:scheduler": "tsx examples/scheduler.ts",
    "example:scheduler-showcase": "tsx examples/scheduler-showcase.ts",
    "example:state": "tsx examples/state.ts",
    "example:ui": "tsx examples/ui-lifecycle.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
